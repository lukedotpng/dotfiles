shell-integration="fish"
theme="Catppuccin Mocha"

gtk-single-instance=false
window-decoration=server

background-opacity=.95

font-family="Lilex Regular"
font-feature = -liga
font-feature = -calt
font-feature = -dlig

keybind=ctrl+shift+tab=toggle_tab_overview
keybind=ctrl+shift+w=close_surface
keybind=ctrl+shift+alt+arrow_up=resize_split:up,10
keybind=ctrl+shift+alt+arrow_right=resize_split:right,10
keybind=ctrl+shift+alt+arrow_down=resize_split:down,10
keybind=ctrl+shift+alt+arrow_left=resize_split:left,10
